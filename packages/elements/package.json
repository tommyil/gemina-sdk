{
  "name": "@gemina/elements",
  "version": "0.1.2",
  "description": "Embeddable browser UI for Gemina Document Intelligence — a drop-in React chat component plus a security-hardened session-token manager. The API key never enters the browser.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tommyil/gemina-sdk.git",
    "directory": "packages/elements"
  },
  "homepage": "https://gemina.co",
  "bugs": {
    "url": "https://github.com/tommyil/gemina-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./token-manager": {
      "types": "./dist/token-manager.d.ts",
      "import": "./dist/token-manager.js",
      "require": "./dist/token-manager.cjs"
    },
    "./chat": {
      "types": "./dist/chat.d.ts",
      "import": "./dist/chat.js",
      "require": "./dist/chat.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gemina",
    "chat",
    "react",
    "document-intelligence",
    "invoice",
    "rag",
    "embeddable"
  ],
  "dependencies": {
    "@gemina/sdk": "^0.1.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "happy-dom": "^17.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
